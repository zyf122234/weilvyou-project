DEEPSEEK_API_KEY=您的ApiKey
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_COMPLETIONS_PATH=/v1/chat/completions
DEEPSEEK_TEMPERATURE=0.4

TZ=Asia/Shanghai
JAVA_RUNTIME_IMAGE=ubuntu:22.04

MYSQL_IMAGE=mysql:8.0.36
MYSQL_HOST=mysql
MYSQL_INTERNAL_PORT=3306
MYSQL_HOST_PORT=3307
MYSQL_ROOT_USER=root
MYSQL_ROOT_PASSWORD=123456
MYSQL_CHARACTER_SET_SERVER=utf8mb4
MYSQL_COLLATION_SERVER=utf8mb4_unicode_ci
NACOS_DB_NAME=nacos
USER_DATASOURCE_URL=jdbc:mysql://mysql:3306/travel_user_db?useSSL=false&serverTimezone=Asia/Shanghai&useUnicode=true&characterEncoding=utf8
PRODUCT_DATASOURCE_URL=jdbc:mysql://mysql:3306/travel_product_db?useSSL=false&serverTimezone=Asia/Shanghai&useUnicode=true&characterEncoding=utf8
ORDER_DATASOURCE_URL=jdbc:mysql://mysql:3306/travel_order_db?useSSL=false&serverTimezone=Asia/Shanghai&useUnicode=true&characterEncoding=utf8
AI_DATASOURCE_URL=jdbc:mysql://mysql:3306/travel_ai_db?useSSL=false&serverTimezone=Asia/Shanghai&useUnicode=true&characterEncoding=utf8

NACOS_IMAGE=nacos/nacos-server:v2.3.1
NACOS_HOST=nacos
NACOS_PORT=8848
NACOS_GRPC_PORT=9848
NACOS_RAFT_PORT=9849
NACOS_SERVER_ADDR=nacos:8848
NACOS_JVM_XMS=256m
NACOS_JVM_XMX=256m
NACOS_NAMESPACE=
NACOS_USERNAME=
NACOS_PASSWORD=

RABBITMQ_IMAGE=rabbitmq:3.12.12-management
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

NGINX_IMAGE=nginx:1.25-alpine
NGINX_PORT=80
NGINX_HOME_CACHE_TTL=60s
NGINX_CACHE_MAX_SIZE=1g
NGINX_CACHE_INACTIVE=10m
NGINX_WORKER_CONNECTIONS=4096
NGINX_WORKER_RLIMIT_NOFILE=65535
NGINX_KEEPALIVE_TIMEOUT=65s
NGINX_KEEPALIVE_REQUESTS=10000
NGINX_GZIP_COMP_LEVEL=4
NGINX_GZIP_MIN_LENGTH=1024
NGINX_UPSTREAM_KEEPALIVE=128

REDIS_IMAGE=redis:7.2-alpine
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TIMEOUT=3s
REDIS_POOL_MAX_ACTIVE=32
REDIS_POOL_MAX_IDLE=16
REDIS_POOL_MIN_IDLE=4
REDIS_POOL_MAX_WAIT=500ms
AI_REDIS_POOL_MAX_ACTIVE=16
AI_REDIS_POOL_MAX_IDLE=8
AI_REDIS_POOL_MIN_IDLE=2

ELASTICSEARCH_IMAGE=elasticsearch:7.12.1
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_HOST_PORT=9210
ELASTICSEARCH_TRANSPORT_PORT=9300
ELASTICSEARCH_CLUSTER_NAME=travel-es
ELASTICSEARCH_NODE_NAME=travel-es-node
ELASTICSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
TRAVEL_ELASTICSEARCH_URIS=http://elasticsearch:9200
KIBANA_IMAGE=kibana:7.12.1
KIBANA_PORT=5601
KIBANA_ELASTICSEARCH_HOSTS=http://elasticsearch:9200

SKYWALKING_AGENT_IMAGE=apache/skywalking-java-agent:9.6.0-java17
SKYWALKING_OAP_IMAGE=apache/skywalking-oap-server:9.6.0-java17
SKYWALKING_UI_IMAGE=apache/skywalking-ui:9.6.0-java17
SKYWALKING_OAP_HOST=skywalking-oap
SKYWALKING_GRPC_PORT=11800
SKYWALKING_HTTP_PORT=12800
SKYWALKING_UI_PORT=18080
SKYWALKING_UI_INTERNAL_PORT=8080
SKYWALKING_COLLECTOR_BACKEND_SERVICES=skywalking-oap:11800
SKYWALKING_UI_OAP_ADDRESS=http://skywalking-oap:12800

SEATA_IMAGE=seataio/seata-server:2.0.0
SEATA_HOST=seata-server
SEATA_CONSOLE_PORT=7091
SEATA_SERVICE_PORT=8091
SEATA_CONFIG_GROUP=SEATA_GROUP
SEATA_TX_SERVICE_GROUP=travel_tx_group
SEATA_CONFIG_DATA_ID=seataServer.properties
SEATA_CLUSTER=default
SEATA_CONSOLE_USERNAME=seata
SEATA_CONSOLE_PASSWORD=seata
SEATA_SECRET_KEY=SeataSecretKey0c382ef121d778043159209298fd40bf3850a017
SEATA_TOKEN_VALIDITY_MS=1800000
SEATA_LOG_HOME=/root/logs/seata
SEATA_LOGSTASH_DESTINATION=127.0.0.1:4560
SEATA_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
SEATA_KAFKA_LOG_TOPIC=logback_to_logstash

XXL_JOB_ADMIN_IMAGE=xuxueli/xxl-job-admin:2.4.1
XXL_JOB_ADMIN_PORT=9080
XXL_JOB_ADMIN_INTERNAL_PORT=8080
XXL_JOB_DB_NAME=xxl_job
XXL_JOB_ENABLED=true
XXL_JOB_ADMIN_ADDRESSES=http://xxl-job-admin:8080/xxl-job-admin
XXL_JOB_ACCESS_TOKEN=travel-xxl-job-token
XXL_JOB_ORDER_EXECUTOR_APPNAME=travel-order-executor
XXL_JOB_ORDER_EXECUTOR_ADDRESS=
XXL_JOB_ORDER_EXECUTOR_IP=
XXL_JOB_ORDER_EXECUTOR_PORT=9999
XXL_JOB_ORDER_EXECUTOR_LOG_PATH=/app/logs/xxl-job/jobhandler
XXL_JOB_ORDER_EXECUTOR_LOG_RETENTION_DAYS=30

TRAVEL_GATEWAY_PORT=8080
TRAVEL_USER_PORT=8081
TRAVEL_PRODUCT_PORT=8082
TRAVEL_ORDER_PORT=8084
TRAVEL_AI_PORT=8085
TRAVEL_GATEWAY_JAVA_OPTS=-Xms256m -Xmx512m -XX:MaxMetaspaceSize=256m -XX:+UseContainerSupport -XX:+ExitOnOutOfMemoryError
TRAVEL_USER_JAVA_OPTS=-Xms256m -Xmx768m -XX:MaxMetaspaceSize=256m -XX:+UseContainerSupport -XX:+ExitOnOutOfMemoryError
TRAVEL_PRODUCT_JAVA_OPTS=-Xms256m -Xmx768m -XX:MaxMetaspaceSize=256m -XX:+UseContainerSupport -XX:+ExitOnOutOfMemoryError
TRAVEL_ORDER_JAVA_OPTS=-Xms256m -Xmx768m -XX:MaxMetaspaceSize=256m -XX:+UseContainerSupport -XX:+ExitOnOutOfMemoryError
TRAVEL_AI_JAVA_OPTS=-Xms256m -Xmx512m -XX:MaxMetaspaceSize=256m -XX:+UseContainerSupport -XX:+ExitOnOutOfMemoryError
TRAVEL_GATEWAY_MEMORY_LIMIT=900m
TRAVEL_USER_MEMORY_LIMIT=1200m
TRAVEL_PRODUCT_MEMORY_LIMIT=1200m
TRAVEL_ORDER_MEMORY_LIMIT=1200m
TRAVEL_AI_MEMORY_LIMIT=900m
TRAVEL_USER_BASE_URL=http://travel-user:8081
TRAVEL_UPLOAD_BASE_DIR=/app/uploads
TRAVEL_UPLOAD_AVATAR_DIR=/app/uploads/avatars
TRAVEL_UPLOAD_PRODUCT_DIR=/app/uploads/products
TRAVEL_UPLOAD_MAX_FILE_SIZE=5MB
TRAVEL_UPLOAD_MAX_REQUEST_SIZE=5MB

TRAVEL_JWT_SECRET=travel-jwt-secret-key-must-be-at-least-256-bits-long
TRAVEL_JWT_EXPIRATION_MS=86400000

GATEWAY_CORS_ALLOWED_ORIGIN_PATTERNS=*
GATEWAY_CORS_ALLOWED_METHODS=*
GATEWAY_CORS_ALLOWED_HEADERS=*
GATEWAY_CORS_ALLOW_CREDENTIALS=true

FEIGN_SENTINEL_ENABLED=true
USER_LOGIN_SENTINEL_QPS=10
USER_ORDER_SERVICE_HOST=travel-order
AI_LAZY_INITIALIZATION=true

USER_DATASOURCE_MAX_POOL_SIZE=30
USER_DATASOURCE_MIN_IDLE=10
AI_DATASOURCE_MAX_POOL_SIZE=20
AI_DATASOURCE_MIN_IDLE=5
DATASOURCE_CONNECTION_TIMEOUT=30000
CACHE_REDIS_TIME_TO_LIVE=30m
CACHE_REDIS_CACHE_NULL_VALUES=false

PRODUCT_HOME_HOTEL_CACHE_REDIS_KEY=hotel:home:all
PRODUCT_HOME_HOTEL_CACHE_REDIS_TTL=5m
PRODUCT_HOME_HOTEL_CACHE_LOCAL_TTL=1m
PRODUCT_HOME_HOTEL_CACHE_LOCAL_MAX_SIZE=1
PRODUCT_HOME_HOTEL_CACHE_NGINX_PURGE_ENABLED=true
PRODUCT_HOME_HOTEL_CACHE_NGINX_CACHE_PATH=/var/cache/nginx/travel
